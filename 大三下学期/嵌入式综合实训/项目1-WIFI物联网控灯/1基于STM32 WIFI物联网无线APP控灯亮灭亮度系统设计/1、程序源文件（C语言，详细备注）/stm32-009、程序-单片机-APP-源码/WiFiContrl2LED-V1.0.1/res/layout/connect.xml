<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content" >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="8dp"
            android:paddingLeft="10dp"
            android:paddingTop="8dp"
            android:text="连接目标"
            android:textColor="@color/black"
            android:textSize="24dp" />

        </RelativeLayout>
    
                <View style="@style/my_horizontal_line_style" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="36dp" >

            <TextView
                android:id="@+id/txt_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
        		android:textSize="16dp" 
        		android:paddingLeft="10dp"
       			android:textColor="@color/black"
                android:text="IP地址:" />

            <EditText
                android:id="@+id/etxt_ip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toRightOf="@+id/txt_ip"
            	android:background="@drawable/txt_bg"
                android:ems="10"
                android:inputType="text"
        		android:textSize="16dp" 
       			android:textColor="@color/black"
	            android:layout_margin="1dp"
	            android:paddingLeft="8dp"
	            android:paddingBottom="6dp"
                android:text="192.168.1.101"
	            android:nextFocusDown="@+id/txt_ip" >
            </EditText>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="36dp" >

            <TextView
                android:id="@+id/txt_port"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
        		android:textSize="16dp" 
        		android:paddingLeft="10dp"
       			android:textColor="@color/black"
                android:text="端口号:" />

            <EditText
                android:id="@+id/etxt_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toRightOf="@+id/txt_port"
            	android:background="@drawable/txt_bg"
                android:ems="10"
                android:inputType="number"
        		android:textSize="16dp" 
                android:text="8080"
       			android:textColor="@color/black"
	            android:layout_margin="1dp"
	            android:paddingLeft="8dp"
	            android:paddingBottom="6dp">
            </EditText>
        </RelativeLayout>
    </LinearLayout>
    
                <View style="@style/my_horizontal_line_style" />

     <LinearLayout
         android:layout_width="match_parent"
         android:layout_height="wrap_content">
		
		   <Button
		       android:id="@+id/btn_cancle"
		       android:layout_width="wrap_content"
		       android:layout_height="wrap_content"
		       android:layout_weight="1"
		       android:background="@color/lightBlue"
		       android:textColor="@color/white"
		       android:textSize="20dp"
		       android:paddingTop="10dp"
		       android:paddingBottom="10dp"
		       android:layout_margin="2dp"
		       android:text="取消" 
	            android:nextFocusRight="@+id/tbutton_ok"/>
		
		   <Button
		       android:id="@+id/btn_ok"
		       android:layout_width="wrap_content"
		       android:layout_height="wrap_content"
		       android:layout_weight="1"
		       android:background="@color/lightBlue"
		       android:textColor="@color/white"
		       android:textSize="20dp"
		       android:paddingTop="10dp"
		       android:paddingBottom="10dp"
		       android:layout_margin="2dp"
		       android:text="确定" />

     </LinearLayout>

</LinearLayout>