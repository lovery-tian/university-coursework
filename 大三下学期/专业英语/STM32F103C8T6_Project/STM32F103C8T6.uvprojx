          <OutputDirectory>.\Objects\</OutputDirectory>
          <OutputName>STM32F103C8T6</OutputName>
          <OutputExecutable>1</OutputExecutable>
          <AfterMake>
            <RunUserProg1>0</RunUserProg1>
            <RunUserProg2>0</RunUserProg2>
